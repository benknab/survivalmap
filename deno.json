{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno task db:migrate && vite --host 0.0.0.0",
    "check": "deno check src/main.ts src/client.ts vite.config.ts drizzle.config.ts src/dev/lint_file_names.ts",
    "db:generate": "deno run -A npm:drizzle-kit@beta generate",
    "db:migrate": "deno run -A npm:drizzle-kit@beta migrate",
    "lint": "deno lint && deno task lint:file-names",
    "lint:file-names": "deno run --allow-read src/dev/lint_file_names.ts",
    "fmt": "deno fmt",
    "build": "vite build",
    "start": "deno task db:migrate && deno serve -A _fresh/server.js"
  },
  "imports": {
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "@libsql/client": "npm:@libsql/client@^0.17.3",
    "@tanstack/react-query": "npm:@tanstack/react-query@^5.59.0",
    "drizzle-kit": "npm:drizzle-kit@beta",
    "drizzle-orm": "npm:drizzle-orm@beta",
    "drizzle-orm/libsql": "npm:drizzle-orm@beta/libsql",
    "drizzle-orm/sqlite-core": "npm:drizzle-orm@beta/sqlite-core",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.2",
    "react": "npm:preact@^10.29.2/compat",
    "react-dom": "npm:preact@^10.29.2/compat",
    "react/jsx-runtime": "npm:preact@^10.29.2/jsx-runtime",
    "vite": "npm:vite@^7.3.3",
    "zod": "npm:zod@^4.4.3"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"],
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended", "fresh", "jsx", "react", "jsr", "workspace"],
      "include": [
        "ban-untagged-todo",
        "camelcase",
        "default-param-last",
        "eqeqeq",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "guard-for-in",
        "no-await-in-loop",
        "no-boolean-literal-for-arguments",
        "no-console",
        "no-eval",
        "no-external-import",
        "no-implicit-declare-namespace-export",
        "no-inferrable-types",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-self-compare",
        "no-sparse-arrays",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-top-level-await",
        "no-undef",
        "no-useless-rename",
        "prefer-ascii",
        "single-var-declarator",
        "triple-slash-reference"
      ]
    }
  },
  "exclude": ["**/_fresh/*", "dist/"]
}
