{
  "tasks": {
    "dev": "deno run --allow-net --allow-env=PORT,NODE_ENV --watch=src/ src/main.tsx",
    "check": "deno check src/main.tsx",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "build": "deno cache src/main.tsx",
    "start": "deno run --allow-net --allow-env=PORT,NODE_ENV src/main.tsx"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.10.7",
    "react": "npm:react@^19.2.1",
    "react/jsx-runtime": "npm:react@^19.2.1/jsx-runtime",
    "react-dom/server": "npm:react-dom@^19.2.1/server"
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom", "dom.iterable", "dom.asynciterable", "es2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["npm:@types/react@^19.2.7", "npm:@types/react-dom@^19.2.3"],
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "nodeModulesDir": "auto"
}
